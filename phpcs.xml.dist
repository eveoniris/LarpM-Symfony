<?xml version="1.0"?>
<ruleset name="Project">

    <description>PSR-12 check — PHP 8.4</description>

    <!-- Dossiers analysés -->
    <file>src</file>
    <file>tests</file>

    <!-- Version PHP cible -->
    <config name="php_version" value="80400"/>

    <!-- PSR-12 uniquement (seul standard installé par défaut) -->
    <!-- Le style Symfony est géré par PHP CS Fixer (.php-cs-fixer.dist.php) -->
    <rule ref="PSR12">
        <exclude name="PSR12.Files.FileHeader"/>
    </rule>

    <rule ref="Generic.PHP.RequireStrictTypes"/>

    <!-- Encodage -->
    <arg name="encoding" value="UTF-8"/>
    <!-- Affichage : couleurs + progression + source de la règle -->
    <arg name="colors"/>
    <arg value="sp"/>

</ruleset>
