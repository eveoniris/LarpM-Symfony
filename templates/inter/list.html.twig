{% extends "base.html.twig" %}

{% block title %}Inter-jeux{% endblock title %}

{% block body %}

    {% include '_partials/breadcrumb.twig' with {'items': [{'name': 'Liste des inter-jeux'}]} %}

    <div class="well well-sm">
        <div class="header">
            <h5>Liste des inter-jeux <small>( {{ paginator|length }} )</small></h5>
        </div>

        {% set canAdd = {'title': 'Créer un inter-jeu', 'path': path('inter.add')} %}
        {% include '_partials/formListSearch.twig' with {
            'canAdd': canAdd,
            'actionPath': path('inter.list')
        } %}
    </div>

    {% include '_partials/pagination.html.twig' %}

    <div class="table-responsive">
    <table class="table table-striped table-bordered table-sm">
        {% include '_partials/thead.twig' with {'route': 'inter.list', 'rows': [
            {'name': 'Id',            'field': 'id',        'css': 'text-center'},
            {'name': 'Nom',           'field': 'nom',       'css': 'text-center'},
            {'name': 'Année en jeu',  'field': 'anneeJeu',  'css': 'text-center'},
            {'name': 'Date réelle',   'field': 'dateReel',  'css': 'text-center'},
            {'name': 'État',                                 'css': 'text-center'},
            {'name': 'Actions',                              'css': 'text-center'},
        ]} %}
        <tbody>
        {% for interJeu in paginator %}
            <tr>
                <td class="text-center">{{ interJeu.id }}</td>
                <td>{{ interJeu.nom|highlight(pagerService.searchValue) }}</td>
                <td class="text-center">{{ interJeu.anneeJeu|highlight(pagerService.searchValue) }}</td>
                <td class="text-center">{{ interJeu.dateReel|date('d/m/Y') }}</td>
                <td class="text-center">
                    {% set etat = interJeu.etat %}
                    {% if etat.value == 'valide' %}
                        <span class="badge bg-success">{{ etat.label }}</span>
                    {% elseif etat.value == 'termine' %}
                        <span class="badge bg-secondary">{{ etat.label }}</span>
                    {% elseif etat.value == 'refuse' %}
                        <span class="badge bg-danger">{{ etat.label }}</span>
                    {% else %}
                        <span class="badge bg-warning text-dark">{{ etat.label }}</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    <div class="btn-toolbar float-end" role="toolbar">
                        <div class="btn-group" role="group">
                            <a class="btn btn-sm btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom"
                               title="Voir le détail"
                               href="{{ path('inter.detail', {'inter': interJeu.id}) }}">
                                <i class="fa fa-eye"></i>
                            </a>
                            <a class="btn btn-sm btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom"
                               title="Modifier"
                               href="{{ path('inter.update', {'inter': interJeu.id}) }}">
                                <i class="fa fa-pencil"></i>
                            </a>
                            {% if interJeu.canGenereteChronologie %}
                                <a class="btn btn-sm btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom"
                                   title="Générer chronologie joueur"
                                   href="{{ path('inter.chronologie', {'inter': interJeu.id}) }}">
                                    <i class="fa fa-clock"></i>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6" class="text-center">Aucun inter-jeu trouvé.</td></tr>
        {% endfor %}
        </tbody>
    </table>
    </div>

    {% include '_partials/pagination.html.twig' %}

{% endblock body %}
