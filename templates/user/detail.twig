{% extends 'base.html.twig' %}

{% block title %}{{ user.displayName }}{% endblock %}

{% block body %}

    {% set isSelfUser = user.id is defined and app.user.id is defined and app.user.id == user.id %}

    <ol class="breadcrumb">
        <li><a href="{{ path('homepage') }}">Accueil</a></li>
        {% if is_granted('ROLE_ORGA', app.user) %}
            <li><a href="{{ path('user.list') }}">Liste des utilisateurs</a></li>{% endif %}
        <li class="active">Détail d'un utilisateur</li>
    </ol>

    {% if isAdmin or canManage or isSelfUser or canReadSecret %}
        <div class="m-2 d-flex justify-content-end">
            <a class="btn btn-secondary"
               href="{{ path('user.personnage.list', {'user': user.id}) }}"><span
                    class="fa fa-users" style="margin-right: 5px;"></span>
                personnages</a>
        </div>
    {% endif %}

    <div class="well well-sm">

        <div class="row">
            <div
                class="{% if is_granted('ROLE_ORGA', user) or isSelfUser %}col-md-6{% else %}col-md-12{% endif %}">

                <div class="header">
                    <h5>{{ user.displayName }}</h5>
                </div>

                <div class="text-muted">
                    Date d'enregistrement {{ user.creationDate|date('d/m/Y') }}
                </div>

                {% if is_granted('ROLE_ORGA', app.user) %}
                    {% if not user.isEnabled %}
                        <div style="margin-bottom: 5px;">
                            <span class="label label-danger">Pending email confirmation</span>
                            <span class="text-muted">(visible to admins only)</span>
                            <span class="text-muted">{{ user.email }}</span>
                            <span class="text-muted"><a
                                    href="{{ path('etatCivil.detail', {'etatCivil': user.etatCivil.id}) }}">Etat-civil</a></span>
                            <div class="m-2">
                                <a class="btn btn-secondary btn-sm"
                                   href="{{ path('user.resend-confirmation', {'user': user.id}) }}"><span
                                        class="fa fa-envelope" style="margin-right: 5px;"></span>Renvoyer l'email de confirmation</a>
                            </div>
                        </div>

                    {% endif %}
                    <div class="text-muted">
                        {{ user.email }}
                    </div>
                {% endif %}

                <div class="m-2 d-flex justify-content-between">
                    {% if isAdmin or not isSelfUser %}
                        <a class="btn btn-secondary" href="{{ path('message.new', {'to': user.id}) }}"><span
                                class="fa fa-envelope"
                                style="margin-right: 5px;"></span>Contacter</a>
                    {% endif %}

                    {% if isAdmin or isSelfUser %}
                        <a class="btn btn-secondary" href="{{ path('user.edit', {'user': user.id}) }}"><span
                                class="fa fa-edit"
                                style="margin-right: 5px;"></span>Modifier</a>
                        {# todo ?
                        <a class="btn btn-secondary" href="{{ path('etatCivil.update', {'etatCivil': user.etatCivil.id}) }}"><span
                                class="fa fa-edit"
                                style="margin-right: 5px;"></span>Modifier Etat-Civil</a>
                        #}
                    {% endif %}
                </div>

                {% if is_granted('ROLE_SUPER_ADMIN', user) %}
                    <div class="w-100">
                        <div class="m-2 d-flex justify-content-center">
                            <a class="btn btn-outline-secondary border-danger"
                               href="{{ path('user.detail', {'user': user.id, '_switch_user': user.email}) }}"
                               data-bs-toggle="tooltip"
                               data-bs-placement="top" title="Se connecter comme l'utilisateur">
                                <i class="fa fa-user-ninja text-danger"
                                ></i> Simuler sa session</a>
                        </div>
                    </div>

                    {# Support : génération manuelle d'un lien temporaire à transmettre à l'utilisateur #}
                    <div class="w-100 mt-3">
                        <div class="card border-danger">
                            <div class="card-header py-1">
                                <i class="fa fa-life-ring text-danger" style="margin-right: 5px;"></i>Support — lien temporaire
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-2">
                                    À utiliser uniquement si l'utilisateur ne reçoit pas ses emails. Le lien généré est
                                    <strong>à usage unique</strong>, <strong>invalide tout lien précédent</strong> et doit être
                                    transmis par un canal de confiance.
                                </p>

                                {% set supportLink = app.flashes('support_link')|first %}
                                {% set supportLinkType = app.flashes('support_link_type')|first %}
                                {% if supportLink %}
                                    <div class="alert alert-warning">
                                        <div class="mb-1">
                                            <strong>Lien {{ supportLinkType == 'confirm' ? 'de validation de compte' : 'de réinitialisation de mot de passe' }} généré</strong>
                                            {% if supportLinkType != 'confirm' %}
                                                <span class="text-muted">(valable 24h)</span>
                                            {% endif %}
                                        </div>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="supportLinkInput" readonly
                                                   value="{{ supportLink }}"
                                                   onclick="this.select();">
                                            <button class="btn btn-secondary" type="button"
                                                    onclick="navigator.clipboard.writeText(document.getElementById('supportLinkInput').value); this.innerHTML='&lt;i class=&quot;fa fa-check&quot;&gt;&lt;/i&gt; Copié';">
                                                <i class="fa fa-copy"></i> Copier
                                            </button>
                                        </div>
                                    </div>
                                {% endif %}

                                <div class="d-flex flex-wrap gap-2">
                                    <form method="post" action="{{ path('user.support.reset-link', {'user': user.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('support-reset-link-' ~ user.id) }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fa fa-key" style="margin-right: 5px;"></i>Lien de réinitialisation du mot de passe
                                        </button>
                                    </form>

                                    {% if not user.isEnabled %}
                                        <form method="post" action="{{ path('user.support.confirm-link', {'user': user.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('support-confirm-link-' ~ user.id) }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="fa fa-user-check" style="margin-right: 5px;"></i>Lien de validation du compte
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endif %}

            </div>

            {% if is_granted('ROLE_ORGA', user) or isSelfUser or canReadSecret %}
                <div class="col-md-6">

                    <div class="header">
                        <h5>Participations</h5>
                    </div>

                    <div class="list-group">
                        {% set hasDefaultPersonnage = false %}
                        {% for participant in user.participants %}
                            <div class="list-group-item">
                                <div>
                                    <a href="{{ path('participant.detail', {'participant': participant.id}) }}">Participe</a>
                                    à <a
                                        href="{{ path('gn.detail', {'gn': participant.gn.id}) }}">{{ participant.gn.label }}</a>.
                                </div>

                                {% if participant.groupeGn %}
                                    <div>
                                        Membre du groupe :
                                        {% if is_granted('ROLE_ORGA', app.user) %}
                                            <a href="{{ path('groupe.detail',{'groupe':participant.groupeGn.groupe.id}) }}">#{{ participant.groupeGn.groupe.numero }}
                                                - {{ participant.groupeGn.groupe.nom }}</a>
                                        {% else %}
                                            <a href="{{ path('groupe.detail',{'groupeGn':participant.groupeGn.id, 'groupe':participant.groupeGn.groupe.id}) }}">#{{ participant.groupeGn.groupe.numero }}
                                                - {{ participant.groupeGn.groupe.nom }}</a>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                {% if participant.personnage %}
                                    <div>
                                        Personnage :
                                        {% if is_granted('ROLE_ORGA', app.user) %}
                                            <a href="{{ path('personnage.detail',{'personnage': participant.personnage.id}) }}">{{ participant.personnage.identity }}</a>
                                        {% else %}
                                            <a href="{{ path('gn.personnage',{'gn': participant.gn.id}) }}">{{ participant.personnage.identity }}</a>
                                        {% endif %}
                                        {% if participant.user.personnage is defined and participant.personnage.id == participant.user.personnage.id %}
                                            {% set hasDefaultPersonnage = true %}
                                            <span class="badge rounded-pill text-bg-secondary">Actif</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        {% endfor %}
                        {% if not hasDefaultPersonnage and canManage %}
                            <div class="mt-2">
                                {% include '_partials/cardNotif.twig' with {'type' : 'danger', 'content' : "Vous n'avez pas de personnage actif"} %}
                            </div>
                        {% endif %}
                    </div>

                    {% if canManage %}
                        <div class="m-2 d-flex justify-content-between">
                            {% if personnageService.canCreatePersonnage(user) %}
                                <a class="btn btn-secondary"
                                   href="{{ path('user.personnage.add', {'user': user.id}) }}"><span
                                        class="fa fa-user" style="margin-right: 5px;"></span>
                                    Nouveau</a>
                            {% endif %}
                            <a class="btn btn-secondary"
                               href="{{ path('user.personnageDefault', {'user': user.id}) }}"><span
                                    class="fa fa-users" style="margin-right: 5px;"></span>
                                Choisir le personnage actif</a>
                        </div>
                    {% endif %}

                </div>
            {% endif %}
        </div>


    </div>


{% endblock %}
