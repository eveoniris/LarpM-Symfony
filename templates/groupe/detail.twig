{% extends "base.html.twig" %}

{% block title %}{{ groupe.nom }}{% endblock title %}
{% block body %}

    {% if tab is not defined %}
        {% set tab = 'detail' %}
    {% endif %}
    {% set isAdmin = is_granted('ROLE_REGLE', app.user) or is_granted('ROLE_ADMIN', app.user) or is_granted('ROLE_SCENARISTE', app.user) %}
    {% set groupeGnId = groupeGn is not null ? groupeGn.id : app.request.query.all['groupeGn']|default(null) %}

    {% set breadcrumb = [] %}
    {% if isAdmin %}
        {% set breadcrumb = breadcrumb|merge([{'name' : 'Liste des groupes', 'route': path('groupe.list') }]) %}
    {% endif %}
    {% set breadcrumb = breadcrumb|merge( [{'name': groupe.label, 'route': path('groupe.detail', {'groupe': groupe.id})},{'name' : 'Détail d\'un groupe' }]) %}

    {% include '_partials/breadcrumb.twig' with {'items' :breadcrumb} %}

    <div class="d-flex justify-content-end">
        <div class="w-auto mb-2 p-0">
            {% if is_granted('ROLE_SCENARISTE', app.user) %}
                <div class="d-flex justify-content-end">
                    <div class="btn-toolbar d-flex flex-wrap justify-content-end gap-2 mb-2 p-0" role="toolbar">
                        <div class="btn-group flex-wrap" role="group">
                            <a class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom"
                               title="Modifier"
                               href="{{ path('groupe.add') }}"><i
                                    class="fa fa-plus"></i> Ajouter</a>
                            <a class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom"
                               title="Modifier"
                               href="{{ path('groupe.update',{'groupe':groupe.id}) }}"><i
                                    class="fa fa-pencil"></i> Modifier</a>
                            <a class="btn btn-secondary" data-bs-toggle="tooltip" data-bs-placement="bottom"
                               title="Supprimer"
                               href="{{ path('groupe.delete',{'groupe':groupe.id}) }}"><i
                                    class="fa fa-eraser"></i> Supprimer</a>

                            <div class="btn-group dropdown" role="group" aria-label="...">
                                <button type="button" class="btn btn-secondary dropdown-toggle"
                                        data-bs-toggle="dropdown"
                                        aria-haspopup="true" aria-expanded="false">
                                    Imprimer
                                    <span class="caret"></span>
                                </button>
                                <ul class="dropdown-menu p-0 border-2 rounded-3 border-secondary">
                                    <li class="d-grid gap-2 rounded-2">
                                        <a class="btn btn-sm btn-secondary rounded-0 rounded-top-2"
                                           href="{{ path('groupe.print.materiel.groupe', {'groupe' : groupe.id}) }}">
                                            Matériel nécessaire (groupe)</a></li>
                                    <li class="d-grid gap-2">
                                        <a class="btn btn-sm btn-secondary rounded-0"
                                           href="{{ path('groupe.print.materiel', {'groupe' : groupe.id}) }}">
                                            Matériel nécessaire (personnages)</a></li>
                                    <li class="d-grid gap-2">
                                        <a class="btn btn-sm btn-secondary rounded-0"
                                           href="{{ path('groupe.print.materiel', {'groupe' : groupe.id, 'compact': 1}) }}">
                                            Matériel nécessaire (2 personnages/feuille)</a></li>
                                    <li class="d-grid gap-2">
                                        <a class="btn btn-sm btn-secondary rounded-0"
                                           href="{{ path('groupe.print.perso', {'groupe' : groupe.id}) }}">
                                            Fiche de perso</a></li>
                                    <li class="d-grid gap-2">
                                        <a class="btn btn-sm btn-secondary rounded-0"
                                           href="{{ path('groupe.print.perso', {'groupe' : groupe.id, 'qrCode': 1}) }}">
                                            Fiche de perso QrCode</a></li>
                                    <li class="d-grid gap-2 rounded-2">
                                        <a class="btn btn-sm btn-secondary rounded-0 rounded-bottom-2"
                                           href="{{ path('groupe.print.background', {'groupe' : groupe.id}) }}">
                                            Background</a>
                                    </li>

                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="well well-sm">

        <div class="header">
            <h4>Détail d'un groupe</h4>
        </div>

        <h4 class="bold">{{ groupe.label }}</h4>

        <div class="row" style="min-height:300px;">
            <div class="col-md-12">
                <div>
                    {# Navigation mobile par offcanvas (visible uniquement sur xs/sm) #}
                    {% set groupeTabLabels = {'detail': 'Détail', 'membres': 'Membres', 'domaine': 'Jeu de domaine', 'backgrounds': 'Backgrounds', 'debriefings': 'Debriefings', 'enveloppe': 'Enveloppe'} %}
                    {% set membresItems = [] %}
                    {% for session in groupe.groupeGns|reverse %}
                        {% set membresItems = membresItems|merge([{
                            'path': path('groupe.detail.tab', app.request.query.all|merge({'groupe': groupe.id, 'tab': 'membres', 'gn': session.gn.id, 'groupeGn': session.id})),
                            'label': session.gn.label,
                            'active': tab == 'membres' and groupeGnId is not null and groupeGnId == session.id
                        }]) %}
                    {% endfor %}
                    {% if membresItems|length == 0 %}
                        {% set membresItems = [{'path': path('groupeGn.add', {'groupe': groupe.id}), 'label': 'Ajouter une session', 'active': false}] %}
                    {% endif %}
                    {% set domaineItems = [] %}
                    {% for session in groupe.groupeGns|reverse %}
                        {% set domaineItems = domaineItems|merge([{
                            'path': path('groupe.detail.groupeGn', app.request.query.all|merge({'groupe': groupe.id, 'tab': 'domaine', 'gn': session.gn.id, 'groupeGn': session.id})),
                            'label': session.gn.label,
                            'active': tab == 'domaine' and groupeGnId is not null and groupeGnId == session.id
                        }]) %}
                    {% endfor %}
                    {% if domaineItems|length == 0 %}
                        {% set domaineItems = [{'path': '#', 'label': 'Aucune session', 'disabled': true}] %}
                    {% endif %}
                    {% set tabGroups = [
                        {'items': [
                            {'path': path('groupe.detail.tab', app.request.query.all|merge({'groupe': groupe.id, 'tab': 'detail', 'groupeGn': groupeGnId|default()})), 'label': 'Détail', 'active': tab == 'detail'}
                        ]},
                        {'label': 'Membres', 'items': membresItems},
                    ] %}
                    {% if canRead %}
                        {% set tabGroups = tabGroups|merge([
                            {'label': 'Jeu de domaine', 'items': domaineItems},
                            {'items': [
                                {'path': path('groupe.detail.tab', app.request.query.all|merge({'groupe': groupe.id, 'tab': 'backgrounds', 'groupeGn': groupeGnId|default()})), 'label': 'Backgrounds', 'active': tab == 'backgrounds'},
                                {'path': path('groupe.detail.tab', app.request.query.all|merge({'groupe': groupe.id, 'tab': 'debriefings', 'groupeGn': groupeGnId|default()})), 'label': 'Debriefings', 'active': tab == 'debriefings'},
                            ]},
                        ]) %}
                        {% if isAdmin %}
                            {% set tabGroups = tabGroups|merge([
                                {'items': [
                                    {'path': path('groupe.detail.tab', app.request.query.all|merge({'groupe': groupe.id, 'tab': 'enveloppe', 'groupeGn': groupeGnId|default()})), 'label': 'Enveloppe', 'active': tab == 'enveloppe'},
                                ]},
                            ]) %}
                        {% endif %}
                    {% endif %}
                    {% include '_partials/offcanvasTabs.twig' with {
                        'offcanvasId': 'offcanvasGroupeTabs',
                        'title': 'Navigation',
                        'triggerLabel': groupeTabLabels[tab]|default('Navigation'),
                        'groups': tabGroups
                    } %}

                    {# Onglets desktop (cachés sur mobile) #}
                    <ul class="nav nav-tabs d-none d-md-flex">
                        <li class="nav-item">
                            <a class="nav-link{% if tab == 'detail' %} active{% endif %}"
                               href="{{ path('groupe.detail.tab',  app.request.query.all|merge({'groupe': groupe.id,'tab': 'detail', 'groupeGn': groupeGnId|default()})) }}"
                            >Détail</a>
                        </li>


                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle{% if tab == 'membres' %} active{% endif %}"
                               data-bs-toggle="dropdown" href="#" role="button"
                               aria-expanded="false">Membres</a>
                            <ul class="dropdown-menu p-0 border-2 rounded-2 border-secondary">
                                {% for session in groupe.groupeGns|reverse %}
                                    <li class="d-grid gap-2{% if loop.first %} rounded-top-2{% elseif loop.last %} rounded-bottom-2{% endif %}">
                                        <a class="dropdown-item {% if loop.first %} rounded-top-2{% elseif loop.last %} rounded-bottom-2{% endif %}"
                                           href="{{ path('groupe.detail.tab',  app.request.query.all|merge({'groupe': groupe.id,'tab': 'membres', 'gn': session.gn.id, 'groupeGn': session.id})) }}"
                                        >{{ session.gn }}</a></li>
                                {% else %}
                                    <li class="d-grid gap-2 rounded-top-2">
                                        <a class="dropdown-item rounded-top-2"
                                           href="{{ path('groupeGn.add', {'groupe': groupe.id}) }}">Ajouter une
                                            session</a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </li>

                        {% if canRead %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle{% if tab == 'domaine' %} active{% endif %}"
                                   data-bs-toggle="dropdown" href="#" role="button"
                                   aria-expanded="false"
                                >Jeu de domaine</a>
                                <ul class="dropdown-menu p-0 border-2 rounded-2 border-secondary">
                                    {% for session in groupe.groupeGns|reverse %}
                                        <li class="d-grid gap-2{% if loop.first %} rounded-top-2{% elseif loop.last %} rounded-bottom-2{% endif %}">
                                            <a class="dropdown-item {% if loop.first %} rounded-top-2{% elseif loop.last %} rounded-bottom-2{% endif %}"
                                               href="{{ path('groupe.detail.groupeGn',  app.request.query.all|merge({'groupe': groupe.id,'tab': 'domaine', 'gn': session.gn.id, 'groupeGn': session.id})) }}"
                                            >{{ session.gn }}</a></li>
                                    {% else %}
                                        <li class="d-grid gap-2 rounded-top-2">
                                            <div class="dropdown-item rounded-top-2">Aucun</div>
                                        </li>
                                    {% endfor %}

                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link{% if tab == 'backgrounds' %} active{% endif %}"
                                   href="{{ path('groupe.detail.tab',  app.request.query.all|merge({'groupe': groupe.id,'tab': 'backgrounds', 'groupeGn': groupeGnId|default()})) }}"
                                >Backgrounds</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link{% if tab == 'debriefings' %} active{% endif %}"
                                   href="{{ path('groupe.detail.tab',  app.request.query.all|merge({'groupe': groupe.id,'tab': 'debriefings', 'groupeGn': groupeGnId|default()})) }}"
                                >Debriefings</a>
                            </li>

                            {% if isAdmin %}
                                <li class="nav-item">
                                    <a class="nav-link {% if tab == 'enveloppe' %} active{% endif %}"
                                       href="{{ path('groupe.detail.tab',  app.request.query.all|merge({'groupe': groupe.id,'tab': 'enveloppe', 'groupeGn': groupeGnId|default()})) }}"
                                    >Enveloppe</a>
                                </li>
                            {% endif %}
                        {% endif %}
                    </ul>

                    <!-- Tab panes -->
                    <div class="tab-content">
                        <div role="tabpanel" class="tab-pane active" role="tabpanel">
                            {% include "groupe/fragment/#{tab|default('detail')}.twig" with {'groupe': groupe, 'groupeGn': groupeGn, 'gn': gn, 'tab' : tab} %}
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
    {% block javascripts %}

        {{ parent() }}

        <script type="module">
            $(document).ready(function () {
                // allow copy to clipboard
                $('.copyToClipBoard').click(function () {
                    let textToCopy = $($(this).attr('data-target')).text();
                    navigator.clipboard.writeText(textToCopy);
                    $(this).find(".fa").removeClass('fa-copy')
                    $(this).find(".fa").addClass('fa-check')
                    setTimeout(() => {
                        $(this).find(".fa").addClass('fa-copy')
                        $(this).find(".fa").removeClass('fa-check')
                    }, 2000);

                });
            });

        </script>
    {% endblock javascripts %}
