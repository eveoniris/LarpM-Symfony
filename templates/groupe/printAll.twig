{% extends "base.print.twig" %}

{% macro popa(pa) %}
    {%- set po = ((pa - pa % 10) / 10)|round -%}
    {%- set reste = pa % 10 -%}
    {%- if po > 0 %}{{ po }} PO{% endif %}
    {%- if po > 0 and reste > 0 %} {% endif %}
    {%- if reste > 0 %}{{ reste }} PA{% endif %}
    {%- if pa == 0 %}0 PA{% endif %}
{%- endmacro %}

{% block content %}

    {% for groupe in groupes %}

        {% set quete = groupe.quete %}
        {% set groupe = groupe.groupe %}

        <h2>Groupe {{ groupe.numero }} - {{ groupe.nom }}</h2>

        <strong>Les personnages</strong>
        <ul>
            {% for participant in groupe.nextSession.participants %}
                {% if participant.personnage %}
                    <li>#{{ participant.personnage.id }}
                        - {{ participant.personnage.nom }}{% if participant.personnage.surnom %} ({{ participant.personnage.surnom }}){% endif %}</li>
                {% else %}
                    <li>Attention le participant {{ participant.user.username }} / {{ participant.user.email }} n'a pas
                        de personnage
                    </li>
                {% endif %}
            {% endfor %}
        </ul>

        {# Richesse : détail par territoire + PJ depuis la synthèse #}
        {% set richesse = syntheseRichesse[groupe.id] %}
        {% if richesse.total > 0 %}
            <strong>Richesse</strong>
            <ul>
                {% if groupe.hasRichesse %}
                    {% for territoire in groupe.territoires %}
                        {% set pa = 3 * territoire.richesse %}
                        {% if pa > 0 %}
                            <li><strong>{{ _self.popa(pa) }}</strong> fournies par <strong>{{ territoire.nom }}</strong></li>
                        {% endif %}
                    {% endfor %}
                {% endif %}
                {% if groupe.richesse|default(0) > 0 %}
                    <li><strong>{{ _self.popa(groupe.richesse) }}</strong> supplémentaires (groupe)</li>
                {% endif %}
                {% for nom, montant in richesse.pj %}
                    <li><strong>{{ _self.popa(montant) }}</strong> — {{ nom }}</li>
                {% endfor %}
                <li><strong>Total : {{ _self.popa(richesse.total) }}</strong></li>
            </ul>
        {% endif %}

        {# Ressources : synthèse agrégée groupe + PJ #}
        {% set ressources = syntheseRessources[groupe.id] %}
        {% if ressources is not empty %}
            <strong>Ressources</strong>
            <ul>
                {% for label, quantite in ressources %}
                    <li><strong>{{ quantite }} {{ label }}</strong></li>
                {% endfor %}
            </ul>
        {% endif %}

        {# Ingrédients : synthèse agrégée groupe + PJ #}
        {% set ingredients = syntheseIngredients[groupe.id] %}
        {% if ingredients is not empty %}
            <strong>Ingrédients</strong>
            <ul>
                {% for label, quantite in ingredients %}
                    <li><strong>{{ quantite }} {{ label }}</strong></li>
                {% endfor %}
            </ul>
        {% endif %}

        {% if groupe.documents|length > 0 %}
            <strong>Documents</strong>
            <ul>
                {% for document in groupe.documents %}
                    <li>{{ document.code }} -- {{ document.titre }}</li>
                {% endfor %}
            </ul>
        {% endif %}

        {% if groupe.items|length > 0 %}
            <strong>Objets</strong>
            <ul>
                {% for objet in groupe.items %}
                    <li>{{ objet.numero }} - {{ objet.label }}</li>
                {% endfor %}
            </ul>
        {% endif %}

        <strong>Matériel</strong>
        <ul>
            <li>1 sac poubelle transparent (déchets recyclables)</li>
            <li>1 sac poubelle noir (déchets non recyclables)</li>
            <li>Bons douche</li>
            <li>1 Etiquette bannière</li>
            <li>1 Fiche retour de groupe</li>
            {% if groupe.territoires|length > 0 %}
                {% for territoire in groupe.territoires %}
                    <li>1 Feuille du fief <strong>{{ territoire }}</strong></li>
                {% endfor %}
                <li>Lot des titres du domaine</li>
            {% endif %}
            {% if groupe.materielRaw %}
                <li>{{ groupe.materielRaw }}</li>
            {% endif %}
        </ul>

        <hr class="print-page-break"/>
        <div class="print-page-break"></div>

    {% endfor %}

{% endblock content %}
