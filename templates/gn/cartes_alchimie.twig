{% extends "base.print.twig" %}

{% block title %}Cartes Alchimiste/Herboriste - {{ gn.label }}{% endblock %}

{% block style %}
<style>
    * { box-sizing: border-box; }
    body { font-family: sans-serif; font-size: 6pt; margin: 0; padding: 0; }
    .page-title {
        text-align: center;
        font-size: 12pt;
        font-weight: bold;
        padding: 4mm;
    }
    /* Grille Avery L7654 : 4 col × 10 lignes, 45,7 × 25,4 mm */
    .grille {
        display: grid;
        grid-template-columns: repeat(4, 45.7mm);
        column-gap: 2.8mm;
        row-gap: 0;
        padding-top: 10.5mm;
        padding-left: 7.3mm;
    }
    .carte {
        width: 45.7mm;
        height: 25.4mm;
        overflow: hidden;
        padding: 0.8mm 1mm;
        border: 0.3px dashed #bbb;
    }
    .carte-id {
        font-size: 5.5pt;
        font-weight: bold;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
    }
    .carte-barcode svg {
        display: block;
        width: 100%;
        height: auto;
        max-height: 14mm;
    }
    .carte-ean {
        font-family: monospace;
        font-size: 5pt;
        text-align: center;
        line-height: 1;
    }
    .no-cartes { text-align: center; padding: 20px; color: #666; }
    @media print {
        .page-title { display: none; }
        .carte { border: none; }
        @page { margin: 0; }
    }
</style>
{% endblock %}

{% block content %}
<div class="page-title noprint">
    Cartes Alchimiste/Herboriste - {{ gn.label }}
    ({{ cartes|length }} carte(s))
</div>

{% if cartes is empty %}
    <div class="no-cartes">Aucun alchimiste ou herboriste inscrit à ce GN.</div>
{% else %}
    <div class="grille">
        {% for carte in cartes %}
            {% set personnage = carte.participant.personnage %}
            <div class="carte">
                <div class="carte-id">#{{ personnage.identity }}</div>
                <div class="carte-barcode">{{ carte.barcode|raw }}</div>
                <div class="carte-ean">{{ carte.ean }}</div>
            </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}
