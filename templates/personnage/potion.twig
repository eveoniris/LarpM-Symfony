{% extends "base.html.twig" %}

{% block title %}{{ personnage.publicName }}{% endblock title %}

{% block body %}


	{% include '_partials/breadcrumb.twig' with {'items' :
		[
			{'route' : path('personnage.detail', {'personnage':  personnage.id}), 'name' : personnage.nom},
			{'name' : "Choix d'une nouvelle potion"}
		]
	} %}

	<div class="well bs-component">

	<div class="header">
		<h5>Choix d'une nouvelle potion</h5>
	</div>


		{% include '_partials/cardNotif.twig' with {'type' : 'info', 'content' : "Votre compétence vous permet de choisir une nouvelle recette de potion. Le descriptif des potions disponibles est visible en bas de page."} %}

			{{ form(form) }}
	</div>

	{% for potion in potions %}
		<div class="well well-sm">
			<div class="header">
				<h5>{{ potion.label }} - Niveau {{ potion.niveau }}</h5>
			</div>
			<p>{{ potion.description|markdown_to_html }}</p>
		</div>
	{% endfor %}


{% endblock body %}
