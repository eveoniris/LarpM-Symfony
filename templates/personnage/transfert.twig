{% extends "base.html.twig" %}

{% block title %}{{ personnage.publicName }} - Transfert{% endblock title %}

{% block body %}

<div class="container-fluid">

    <ol class="breadcrumb">
        <li><a href="{{ path('homepage') }}">Accueil</a></li>
        <li><a href="{{ path('personnage.list') }}">Liste des personnages</a></li>
        <li><a href="{{ path('personnage.detail', {'personnage': personnage.id}) }}">{{ personnage.publicName }}</a></li>
        <li class="active">Transfert</li>
    </ol>

    <div class="well bs-component mb-4">
        <fieldset>
            <legend>
                Transfert de <strong>{{ personnage.publicName }}</strong>
                {% if personnage.user %}
                    - appartient à <em>{{ personnage.user.username }}</em>
                {% else %}
                    - sans joueur actuellement
                {% endif %}
            </legend>

            {# Option 1 : via participation active #}
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fa fa-ticket"></i>
                        Option 1 - Rattacher à une participation active
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Sélectionnez une participation au GN en cours ou à venir, sans personnage associé.
                        Le personnage sera rattaché à l'utilisateur correspondant et intégré à son groupe.<br />
                        Si l'utilisateur n'apparait pas dans la liste, c'est qu'il doit déjà avoir une participation avec un personnage.
                    </p>
                    {{ form_start(formParticipant, {'attr': {'action': path('personnage.transfert', {'personnage': personnage.id})}}) }}
                        {{ form_row(formParticipant.participant) }}
                        {{ form_row(formParticipant.transfert_participant) }}
                    {{ form_end(formParticipant) }}
                </div>
            </div>

            {# Option 2 : rattachement direct à un utilisateur #}
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fa fa-user"></i>
                        Option 2 - Rattacher directement à un utilisateur
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Rattache uniquement le champ <em>joueur</em> du personnage à cet utilisateur,
                        sans créer ni modifier aucune participation. Le scénariste responsable sera effacé.
                    </p>
                    {{ form_start(formUser, {'attr': {'action': path('personnage.transfert', {'personnage': personnage.id})}}) }}
                        {{ form_row(formUser.user) }}
                        {{ form_row(formUser.transfert_user) }}
                    {{ form_end(formUser) }}
                </div>
            </div>

        </fieldset>
    </div>

</div>

{% endblock body %}
