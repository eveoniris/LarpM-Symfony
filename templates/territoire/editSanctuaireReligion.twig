{% extends "base.html.twig" %}

{% block body %}
    <ol class="breadcrumb">
        <li><a href="{{ path('homepage') }}">Accueil</a></li>
        <li><a href="{{ path('territoire.list') }}">Liste des territoires</a></li>
        <li><a href="{{ path('territoire.detail', {'territoire': territoire.id}) }}">{{ territoire.nom }}</a></li>
        <li class="active">Religion du sanctuaire</li>
    </ol>

    <div class="container-fluid">
        <div class="row">
            <div class="col-xs-12 col-md-6">
                <div class="well bs-component">
                    <div class="header">
                        <h5>Religion du sanctuaire - {{ territoire.nom }}</h5>
                    </div>
                    {{ form_start(form) }}
                    {{ form_row(form.sanctuaireReligion) }}
                    {{ form_row(form.save) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock body %}
