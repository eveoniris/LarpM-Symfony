{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "carbonphp/carbon-doctrine-types": "^3",
    "doctrine/dbal": "^4",
    "doctrine/doctrine-bundle": "^3",
    "doctrine/doctrine-migrations-bundle": "^4",
    "doctrine/orm": "^3",
    "endroid/qr-code-bundle": "*",
    "imagine/imagine": "^1",
    "league/commonmark": "^2",
    "lexik/jwt-authentication-bundle": "^3.2",
    "nelmio/cors-bundle": "^2.6",
    "nesbot/carbon": "^3",
    "phpdocumentor/reflection-docblock": "^5.3",
    "phpstan/phpdoc-parser": "^1.24",
    "symfony/apache-pack": "*",
    "symfony/asset": "8.0.*",
    "symfony/asset-mapper": "8.0.*",
    "symfony/cache": "^8.0",
    "symfony/console": "^8.0",
    "symfony/dependency-injection": "^8.0",
    "symfony/doctrine-messenger": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/expression-language": "^8.0",
    "symfony/flex": "2.*",
    "symfony/form": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/http-client": "^8.0",
    "symfony/intl": "^8.0",
    "symfony/mailer": "^8.0",
    "symfony/mime": "^8.0",
    "symfony/monolog-bundle": "^4.0",
    "symfony/notifier": "^8.0",
    "symfony/process": "^8.0",
    "symfony/property-access": "^8.0",
    "symfony/property-info": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/security-bundle": "^8.0",
    "symfony/serializer": "^8.0",
    "symfony/stimulus-bundle": "^3.0",
    "symfony/string": "^8.0",
    "symfony/translation": "^8.0",
    "symfony/twig-bridge": "8.*",
    "symfony/twig-bundle": "8.*",
    "symfony/ux-autocomplete": "^3.0",
    "symfony/ux-turbo": "^3.0",
    "symfony/validator": "^8.0",
    "symfony/web-link": "^8.0",
    "symfony/yaml": "^8.0",
    "team-reflex/discord-php": "*",
    "twig/extra-bundle": "*",
    "twig/intl-extra": "^3.21",
    "twig/markdown-extra": "*",
    "twig/twig": "^3.26"
  },
  "config": {
    "allow-plugins": {
      "endroid/installer": true,
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd",
      "importmap:install": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "cs": "./vendor/bin/phpcs",
    "cs-fix": "./vendor/bin/phpcbf",
    "phpstan": "php -d memory_limit=-1 vendor/bin/phpstan analyse --no-progress --configuration=phpstan.dist.neon"
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.0.*",
      "docker": true
    }
  },
  "require-dev": {
    "carthage-software/mago": "^1.13.1",
    "dama/doctrine-test-bundle": "^8.6",
    "friendsofphp/php-cs-fixer": "^3.94",
    "jetbrains/phpstorm-stubs": "*",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^12",
    "rector/rector": "^2.3",
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "^3",
    "symfony/browser-kit": "^8.0",
    "symfony/css-selector": "^8.0",
    "symfony/debug-bundle": "^8.0",
    "symfony/maker-bundle": "1.*",
    "symfony/phpunit-bridge": "^8.0",
    "symfony/stopwatch": "^8.0",
    "symfony/web-profiler-bundle": "^8.0",
    "zenstruck/foundry": "^2.9"
  }
}
